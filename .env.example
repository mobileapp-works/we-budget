# Supabase（あとで設定。anon key のみ。service_role key は絶対にクライアントへ置かない）
# 値は Supabase Dashboard > Project Settings > API から取得する
EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# モックモード: true の間は Supabase に接続せず、ダミーデータでUIを動かす
# Supabase を構築したら false にする
EXPO_PUBLIC_USE_MOCK=true

# Sentry（任意。あとで設定）
EXPO_PUBLIC_SENTRY_DSN=

# AdMob バナー広告ユニットID（本番用。未設定・開発ビルドでは Google のテストIDを使う）
# 値は AdMob 管理画面 > アプリ > 広告ユニット から取得する（形式: ca-app-pub-XXXX/XXXX）
# ※アプリ単位の App ID（ca-app-pub-XXXX~XXXX）は env ではなく app.json のプラグイン設定に入れる
EXPO_PUBLIC_ADMOB_BANNER_IOS=
EXPO_PUBLIC_ADMOB_BANNER_ANDROID=
# インタースティシャル（全画面）広告ユニットID（本番用。未設定・開発ビルドではテストID）
EXPO_PUBLIC_ADMOB_INTERSTITIAL_IOS=
EXPO_PUBLIC_ADMOB_INTERSTITIAL_ANDROID=
