# Supabase（あとで設定。anon key のみ。service_role key は絶対にクライアントへ置かない）
# 値は Supabase Dashboard > Project Settings > API から取得する
EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# モックモード: true の間は Supabase に接続せず、ダミーデータでUIを動かす
# Supabase を構築したら false にする
EXPO_PUBLIC_USE_MOCK=true

# Sentry（任意。あとで設定）
EXPO_PUBLIC_SENTRY_DSN=

# AdMob（任意。あとで設定）
EXPO_PUBLIC_ADMOB_BANNER_IOS=
EXPO_PUBLIC_ADMOB_BANNER_ANDROID=
