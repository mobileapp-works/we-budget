{
  "expo": {
    "name": "WeBudget",
    "slug": "we-budget",
    "scheme": "webudget",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.mobileappworks.webudget",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "レシートを撮影して支出を記録するためにカメラを使用します。",
        "NSPhotoLibraryUsageDescription": "保存済みのレシート画像を選択して支出を記録するために写真ライブラリにアクセスします。",
        "NSUserTrackingUsageDescription": "あなたに関連性の高い広告を表示するためにトラッキングの許可をお願いします。",
        "ITSAppUsesNonExemptEncryption": false
      },
      "privacyManifests": {
        "NSPrivacyAccessedAPITypes": [
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategoryUserDefaults",
            "NSPrivacyAccessedAPITypeReasons": [
              "CA92.1"
            ]
          }
        ]
      }
    },
    "android": {
      "package": "com.mobileappworks.webudget",
      "versionCode": 1,
      "edgeToEdgeEnabled": true,
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-localization",
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "保存済みのレシート画像を選択するために写真ライブラリにアクセスします。",
          "cameraPermission": "レシートを撮影するためにカメラを使用します。"
        }
      ],
      "@react-native-community/datetimepicker",
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
